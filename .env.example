# Frontend (Vite) — copy to .env.local for local development
# Only VITE_* vars are exposed to the browser.

# Local (API via Vite proxy in vite.config.ts):
VITE_API_URL=/api/v1

# Production (Netlify) — set in Netlify → Site settings → Environment variables:
# VITE_API_URL=https://YOUR-RAILWAY-API.up.railway.app/api/v1
